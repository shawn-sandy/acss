---
/**
 * TokenSwatch — renders a single color token as a swatch with its name,
 * CSS-var reference, and resolved value.
 *
 * Consumed by the Foundations/Colors page to render the full palette by
 * iterating over the tokens JSON. Keeping this single-swatch component
 * small lets consumers compose whatever grid they want around it.
 */

export interface Props {
  /** The CSS custom property name, without the leading "--". */
  name: string;
  /** Resolved value (from tokens.json $value or the primitive it aliases). */
  value: string;
  /** Optional label override; defaults to the last path segment of `name`. */
  label?: string;
}

const { name, value, label } = Astro.props;
const displayLabel = label ?? name.split("-").slice(-1)[0];
---

<figure class="token-swatch">
  <div
    class="token-swatch__chip"
    style={`background: var(--${name})`}
    aria-hidden="true"
  ></div>
  <figcaption>
    <strong>{displayLabel}</strong>
    <code>--{name}</code>
    <span class="token-swatch__value">{value}</span>
  </figcaption>
</figure>

<style>
  .token-swatch {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border-subtle);
    border-radius: 0.5rem;
    background: var(--color-surface-elevated);
  }
  .token-swatch__chip {
    height: 4rem;
    border-radius: 0.375rem;
    /* Subtle outline so light tokens on light backgrounds remain visible. */
    box-shadow: inset 0 0 0 1px var(--color-border-subtle);
  }
  .token-swatch figcaption {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    font-size: 0.8125rem;
  }
  .token-swatch code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, monospace;
    color: var(--color-text-secondary);
    font-size: 0.75rem;
  }
  .token-swatch__value {
    color: var(--color-text-tertiary);
    font-size: 0.75rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, monospace;
  }
</style>
