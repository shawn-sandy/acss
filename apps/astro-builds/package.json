{
  "name": "astro-fpkit",
  "type": "module",
  "version": "1.3.0",
  "private": true,
  "scripts": {
    "ensure-fpkit-build": "test -f ../../packages/acss/libs/index.js && test -f ../../packages/tokens/libs/tokens.json || npm --prefix ../../packages/acss run build",
    "predev": "npm run ensure-fpkit-build",
    "dev": "astro dev",
    "prebuild": "npm run ensure-fpkit-build",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/react": "^4.1.2",
    "@fpkit/acss": "file:../../packages/acss",
    "@fpkit/tokens": "file:../../packages/tokens",
    "astro": "^5.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
